# 生产环境在 Vercel / 托管平台中配置；勿提交含密钥的 .env。

# 规范站点与 SEO（sitemap、metadataBase）
# NEXT_PUBLIC_SITE_URL=https://tool.jakelee.site

# 可选，与 jakelee.site 主站一致
# NEXT_PUBLIC_SOCIAL_GITHUB_URL=https://github.com/…
# NEXT_PUBLIC_SOCIAL_TWITTER_URL=https://x.com/…

# 仅当启用数据库功能时需要（见 docs/DRIZZLE.md）
# DATABASE_URL=postgresql://…

# 仅当使用 Supabase 客户端功能时需要
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
